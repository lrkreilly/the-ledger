---
import sourceSerifLatinNormal from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-standard-normal.woff2?url';
import sourceSerifLatinItalic from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-standard-italic.woff2?url';
import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interLatin500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface ArticleMeta {
  publishedTime: string;
  modifiedTime: string;
  author: string;
  section: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  // og:image:alt — describes what's actually visible in the OG card. For
  // article pages we pass the headline (it's the dominant text on the card).
  // For other pages the default below describes the default OG card.
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  trimLeft?: string;
  trimRight?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  articleMeta?: ArticleMeta;
  metaAuthor?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  ogImageAlt = 'The Ledger — a decision-quality publication',
  ogType = 'website',
  trimLeft,
  trimRight,
  canonical,
  jsonLd,
  articleMeta,
  metaAuthor,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// Organization carries a stable @id so other schemas (Article publisher,
// WebSite, Person.worksFor, AboutPage.publisher) can reference it by id
// instead of redeclaring the whole entity each time. The graph stitches
// across pages without duplicating the publisher block.
const orgId = new URL('#organization', Astro.site).href;
const frameworkUrl = new URL('/how-the-ledger-works/', Astro.site).href;
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': orgId,
  name: 'The Ledger',
  url: Astro.site?.href,
  logo: {
    '@type': 'ImageObject',
    url: new URL('/logo.png', Astro.site).href,
    width: 512,
    height: 512,
  },
  description:
    'A decision-quality publication. Explains the trade-offs, limits, hidden costs, and consequences most rankings and quick answers skip.',
  // E-E-A-T signals: every policy URL below is a real page the publication
  // holds itself to. publishingPrinciples and ethicsPolicy both point at
  // the framework — it's a single document covering both.
  publishingPrinciples: frameworkUrl,
  correctionsPolicy: `${frameworkUrl}#corrections`,
  ethicsPolicy: frameworkUrl,
};

const jsonLdBlocks = jsonLd
  ? Array.isArray(jsonLd)
    ? [organizationJsonLd, ...jsonLd]
    : [organizationJsonLd, jsonLd]
  : [organizationJsonLd];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link
    rel="preload"
    href={sourceSerifLatinNormal}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <link
    rel="preload"
    href={sourceSerifLatinItalic}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <link
    rel="preload"
    href={interLatin400}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <link
    rel="preload"
    href={interLatin500}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  {metaAuthor && <meta name="author" content={metaAuthor} />}
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:site_name" content="The Ledger" />
  <meta property="og:locale" content="en_GB" />

  {articleMeta && (
    <>
      <meta property="article:published_time" content={articleMeta.publishedTime} />
      <meta property="article:modified_time" content={articleMeta.modifiedTime} />
      <meta property="article:author" content={articleMeta.author} />
      <meta property="article:section" content={articleMeta.section} />
    </>
  )}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#F6F2EA" />
  <link rel="alternate" type="application/rss+xml" title="The Ledger" href="/rss.xml" />

  {jsonLdBlocks.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  {import.meta.env.PROD && (
    <script defer data-domain="theledger.media" src="https://plausible.io/js/script.js"></script>
  )}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <Header trimLeft={trimLeft} trimRight={trimRight} />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>
