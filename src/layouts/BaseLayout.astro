---
import sourceSerifLatinNormal from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-standard-normal.woff2?url';
import sourceSerifLatinItalic from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-standard-italic.woff2?url';

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  trimLeft?: string;
  trimRight?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  ogType = 'website',
  trimLeft,
  trimRight,
  canonical,
  jsonLd,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'The Ledger',
  url: Astro.site?.href,
  logo: new URL('/favicon.svg', Astro.site).href,
  description:
    'A decision-quality publication. Explains the trade-offs, limits, hidden costs, and consequences most rankings and quick answers skip.',
};

const jsonLdBlocks = jsonLd
  ? Array.isArray(jsonLd)
    ? [organizationJsonLd, ...jsonLd]
    : [organizationJsonLd, jsonLd]
  : [organizationJsonLd];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link
    rel="preload"
    href={sourceSerifLatinNormal}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <link
    rel="preload"
    href={sourceSerifLatinItalic}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content="The Ledger" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="The Ledger" href="/rss.xml" />

  {jsonLdBlocks.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  {import.meta.env.PROD && (
    <script defer data-domain="theledger.media" src="https://plausible.io/js/script.js"></script>
  )}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <Header trimLeft={trimLeft} trimRight={trimRight} />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>
