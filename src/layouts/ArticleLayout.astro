---
import BaseLayout from './BaseLayout.astro';
import PaperTrail from '../components/PaperTrail.astro';

interface Update {
  date: Date;
  change: string;
}

interface BasisItem {
  label: string;
  url?: string;
}

interface Retraction {
  date: Date;
  reason: string;
}

interface Props {
  title: string;
  summary: string;
  desk: string;
  deskName: string;
  deskNumeral: string;
  slug: string;
  author: string;
  publishDate: Date;
  modifiedDate?: Date;
  ogImage?: string;
  paperTrail: {
    method: string;
    basis: BasisItem[];
    limits: string;
    timeSpent?: string;
    updates: Update[];
  };
  retracted?: Retraction;
}

const {
  title,
  summary,
  desk,
  deskName,
  deskNumeral,
  slug,
  author,
  publishDate,
  modifiedDate,
  ogImage,
  paperTrail,
  retracted,
} = Astro.props;

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Retraction date counts as the most-recent edit if it's later than
// anything else; this keeps dateModified in JSON-LD honest.
const updateDates: Date[] = paperTrail.updates.map((u) => u.date);
if (retracted) updateDates.push(retracted.date);
const effectiveModified = updateDates.length > 0
  ? updateDates.reduce((latest, d) => (d > latest ? d : latest), publishDate)
  : modifiedDate ?? publishDate;

const canonicalUrl = new URL(`/${desk}/${slug}/`, Astro.site).href;
const siteUrl = Astro.site?.href ?? 'https://theledger.media/';

// Build citation array from basis entries. Entries with a URL become
// CreativeWork objects (schema.org's preferred shape for citations); entries
// without a URL become plain strings. The reasoning-piece marker
// ("Argument from first principles.") is also emitted as a plain string
// since it's not an external citation.
const citation = paperTrail.basis.map((b) =>
  b.url ? { '@type': 'CreativeWork', name: b.label, url: b.url } : b.label,
);

const logoUrl = new URL('/logo.png', Astro.site).href;
const authorUrl = new URL('/about/', Astro.site).href;

const articleJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  // Retracted pieces use schema.org's RetractedArticle type — a recognised
  // signal for editorial retraction that Google and AI ingestors handle
  // distinctly from a live Article.
  '@type': retracted ? 'RetractedArticle' : 'Article',
  headline: title,
  description: summary,
  datePublished: publishDate.toISOString(),
  dateModified: effectiveModified.toISOString(),
  inLanguage: 'en-NZ',
  isAccessibleForFree: true,
  articleSection: deskName,
  author: { '@type': 'Person', name: author, url: authorUrl },
  publisher: {
    '@type': 'Organization',
    name: 'The Ledger',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: logoUrl,
      width: 512,
      height: 512,
    },
  },
  mainEntityOfPage: canonicalUrl,
  citation,
  ...(ogImage ? { image: new URL(ogImage, Astro.site).href } : {}),
};

if (paperTrail.updates.length > 0) {
  articleJsonLd.correction = paperTrail.updates.map((u) => ({
    '@type': 'CorrectionComment',
    text: u.change,
    datePublished: u.date.toISOString(),
  }));
}

if (retracted) {
  articleJsonLd.retractionDate = retracted.date.toISOString();
  articleJsonLd.retractionReason = retracted.reason;
}

const dateFmtRetraction = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: deskName, item: new URL(`/${desk}`, Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};
---
<BaseLayout
  title={`${title} — The Ledger`}
  description={summary}
  ogImage={ogImage}
  ogType="article"
  trimLeft={deskName}
  trimRight={dateFmt.format(publishDate)}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
  metaAuthor={author}
  articleMeta={{
    publishedTime: publishDate.toISOString(),
    modifiedTime: effectiveModified.toISOString(),
    author: author,
    section: deskName,
  }}
>
  <article class="article" data-retracted={retracted ? 'true' : undefined}>
    <header class="article__header">
      <div class="container">
        <nav class="article__crumbs" aria-label="Breadcrumb">
          <a href="/">The Ledger</a>
          <span aria-hidden="true">·</span>
          <a href={`/${desk}`}>{deskName}</a>
        </nav>
        {retracted && <p class="article__retracted-eyebrow">Retracted</p>}
        {!retracted && <p class="article__numeral">{deskNumeral}</p>}
        <h1 class="article__title">{title}</h1>
        <p class="article__standfirst">{summary}</p>
        <div class="article__meta">
          <span>By {author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={publishDate.toISOString()}>{dateFmt.format(publishDate)}</time>
          {retracted ? (
            <>
              <span aria-hidden="true">·</span>
              <span>Retracted <time datetime={retracted.date.toISOString()}>{dateFmt.format(retracted.date)}</time></span>
            </>
          ) : effectiveModified.getTime() !== publishDate.getTime() && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated <time datetime={effectiveModified.toISOString()}>{dateFmt.format(effectiveModified)}</time></span>
            </>
          )}
        </div>
      </div>
    </header>

    <div class="article__body">
      <div class="container">
        <div class="article__prose">
          {retracted ? (
            <aside class="article__retraction" aria-label="Retraction notice">
              <p class="article__retraction-label">Retraction notice</p>
              <p class="article__retraction-lead">
                This piece was retracted on <time datetime={retracted.date.toISOString()}>{dateFmtRetraction.format(retracted.date)}</time>.
                The original argument is no longer available because The Ledger no longer stands behind it.
              </p>
              <p class="article__retraction-reason">{retracted.reason}</p>
              <p class="article__retraction-footer">
                The original Paper Trail is preserved below so readers can see how the retracted conclusion was reached.
              </p>
            </aside>
          ) : (
            <slot />
          )}
          <PaperTrail
            method={paperTrail.method}
            basis={paperTrail.basis}
            limits={paperTrail.limits}
            timeSpent={paperTrail.timeSpent}
            updates={paperTrail.updates}
          />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .article__prose h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 28px;
    line-height: 1.22;
    letter-spacing: -0.012em;
    margin: 56px 0 18px;
    color: var(--ink);
  }
  .article__prose h3 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
    margin: 40px 0 14px;
  }
  .article__prose p {
    margin: 0 0 22px;
  }
  .article__prose strong { font-weight: 500; color: var(--ink); }
  .article__prose em { font-style: italic; }
  .article__prose blockquote {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    line-height: 1.45;
    color: var(--ink);
    border-left: 2px solid var(--accent);
    padding: 4px 0 4px 28px;
    margin: 36px 0;
  }
  .article__prose ul,
  .article__prose ol {
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
  }
  .article__prose ul li {
    position: relative;
    padding-left: 26px;
    margin-bottom: 10px;
    line-height: 1.55;
  }
  .article__prose ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ink-3);
  }
  .article__prose ol {
    counter-reset: artlist;
  }
  .article__prose ol li {
    counter-increment: artlist;
    position: relative;
    padding-left: 36px;
    margin-bottom: 12px;
    line-height: 1.55;
  }
  .article__prose ol li::before {
    content: counter(artlist) ".";
    position: absolute;
    left: 0;
    color: var(--ink-3);
    font-style: italic;
  }
  .article__prose a {
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    transition: color 0.15s, border-color 0.15s;
  }
  .article__prose a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<style>
  .article__header {
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--rule);
  }
  .article__crumbs {
    display: flex;
    gap: 10px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-3);
    margin-bottom: 28px;
  }
  .article__crumbs a { transition: color 0.15s; }
  .article__crumbs a:hover { color: var(--ink); }
  .article__numeral {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-3);
    margin-bottom: 18px;
  }
  .article__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(40px, 6.4vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.022em;
    margin-bottom: 28px;
    max-width: 880px;
    color: var(--ink);
  }
  .article__standfirst {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.2vw, 24px);
    line-height: 1.45;
    color: var(--ink-2);
    max-width: 720px;
    margin-bottom: 36px;
  }
  .article__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
  }

  .article__body { padding: 64px 0 96px; }
  .article__prose {
    max-width: 720px;
    margin: 0 auto;
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.7;
    color: var(--ink);
  }

  /* Retraction state — overrides above when data-retracted is set */
  .article[data-retracted] .article__title,
  .article[data-retracted] .article__standfirst {
    color: var(--ink-3);
    text-decoration: line-through;
    text-decoration-color: var(--rule);
    text-decoration-thickness: 1px;
  }
  .article__retracted-eyebrow {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .article__retraction {
    margin: 16px 0 8px;
    padding: 32px 0;
    border-top: 2px solid var(--accent);
    border-bottom: 1px solid var(--rule);
  }
  .article__retraction-label {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .article__retraction-lead {
    font-family: var(--serif);
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 18px;
  }
  .article__retraction-reason {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 18px;
  }
  .article__retraction-footer {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-3);
    margin: 0;
  }

  @media (max-width: 900px) {
    .article__header { padding: 56px 0 44px; }
    .article__body { padding: 48px 0 72px; }
    .article__prose { font-size: 18px; }
    .article__retraction-lead { font-size: 18px; }
  }
</style>
