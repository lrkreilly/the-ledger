---
import BaseLayout from './BaseLayout.astro';
import PaperTrail from '../components/PaperTrail.astro';

interface Update {
  date: Date;
  change: string;
}

interface Props {
  title: string;
  summary: string;
  desk: string;
  deskName: string;
  deskNumeral: string;
  slug: string;
  author: string;
  publishDate: Date;
  modifiedDate?: Date;
  ogImage?: string;
  paperTrail: {
    method: string;
    sources: string;
    limits: string;
    updates: Update[];
  };
}

const {
  title,
  summary,
  desk,
  deskName,
  deskNumeral,
  slug,
  author,
  publishDate,
  modifiedDate,
  ogImage,
  paperTrail,
} = Astro.props;

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const effectiveModified =
  paperTrail.updates.length > 0
    ? paperTrail.updates.reduce((latest, u) => (u.date > latest ? u.date : latest), publishDate)
    : modifiedDate ?? publishDate;

const canonicalUrl = new URL(`/${desk}/${slug}/`, Astro.site).href;
const siteUrl = Astro.site?.href ?? 'https://theledger.media/';

const articleJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: summary,
  datePublished: publishDate.toISOString(),
  dateModified: effectiveModified.toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'The Ledger',
    url: siteUrl,
  },
  mainEntityOfPage: canonicalUrl,
  ...(ogImage ? { image: new URL(ogImage, Astro.site).href } : {}),
};

if (paperTrail.updates.length > 0) {
  articleJsonLd.correction = paperTrail.updates.map((u) => ({
    '@type': 'CorrectionComment',
    text: u.change,
    datePublished: u.date.toISOString(),
  }));
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: deskName, item: new URL(`/${desk}`, Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};
---
<BaseLayout
  title={`${title} — The Ledger`}
  description={summary}
  ogImage={ogImage}
  ogType="article"
  trimLeft={deskName}
  trimRight={dateFmt.format(publishDate)}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="article">
    <header class="article__header">
      <div class="container">
        <nav class="article__crumbs" aria-label="Breadcrumb">
          <a href="/">The Ledger</a>
          <span aria-hidden="true">·</span>
          <a href={`/${desk}`}>{deskName}</a>
        </nav>
        <p class="article__numeral">{deskNumeral}</p>
        <h1 class="article__title">{title}</h1>
        <p class="article__standfirst">{summary}</p>
        <div class="article__meta">
          <span>By {author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={publishDate.toISOString()}>{dateFmt.format(publishDate)}</time>
          {effectiveModified.getTime() !== publishDate.getTime() && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated <time datetime={effectiveModified.toISOString()}>{dateFmt.format(effectiveModified)}</time></span>
            </>
          )}
        </div>
      </div>
    </header>

    <div class="article__body">
      <div class="container">
        <div class="article__prose">
          <slot />
          <PaperTrail
            method={paperTrail.method}
            sources={paperTrail.sources}
            limits={paperTrail.limits}
            updates={paperTrail.updates}
          />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .article__prose h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 28px;
    line-height: 1.22;
    letter-spacing: -0.012em;
    margin: 56px 0 18px;
    color: var(--ink);
  }
  .article__prose h3 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
    margin: 40px 0 14px;
  }
  .article__prose p {
    margin: 0 0 22px;
  }
  .article__prose strong { font-weight: 500; color: var(--ink); }
  .article__prose em { font-style: italic; }
  .article__prose blockquote {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    line-height: 1.45;
    color: var(--ink);
    border-left: 2px solid var(--accent);
    padding: 4px 0 4px 28px;
    margin: 36px 0;
  }
  .article__prose ul,
  .article__prose ol {
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
  }
  .article__prose ul li {
    position: relative;
    padding-left: 26px;
    margin-bottom: 10px;
    line-height: 1.55;
  }
  .article__prose ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ink-3);
  }
  .article__prose ol {
    counter-reset: artlist;
  }
  .article__prose ol li {
    counter-increment: artlist;
    position: relative;
    padding-left: 36px;
    margin-bottom: 12px;
    line-height: 1.55;
  }
  .article__prose ol li::before {
    content: counter(artlist) ".";
    position: absolute;
    left: 0;
    color: var(--ink-3);
    font-style: italic;
  }
  .article__prose a {
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    transition: color 0.15s, border-color 0.15s;
  }
  .article__prose a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<style>
  .article__header {
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--rule);
  }
  .article__crumbs {
    display: flex;
    gap: 10px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-3);
    margin-bottom: 28px;
  }
  .article__crumbs a { transition: color 0.15s; }
  .article__crumbs a:hover { color: var(--ink); }
  .article__numeral {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-3);
    margin-bottom: 18px;
  }
  .article__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(40px, 6.4vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.022em;
    margin-bottom: 28px;
    max-width: 880px;
    color: var(--ink);
  }
  .article__standfirst {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.2vw, 24px);
    line-height: 1.45;
    color: var(--ink-2);
    max-width: 720px;
    margin-bottom: 36px;
  }
  .article__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
  }

  .article__body { padding: 64px 0 96px; }
  .article__prose {
    max-width: 720px;
    margin: 0 auto;
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.7;
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .article__header { padding: 56px 0 44px; }
    .article__body { padding: 48px 0 72px; }
    .article__prose { font-size: 18px; }
  }
</style>
