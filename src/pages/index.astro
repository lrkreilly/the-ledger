---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const DESK_ORDER = [
  'value-and-trade-offs',
  'home-and-services',
  'internet-claims',
  'work-and-standards',
  'education-and-learning',
] as const;

// Featured desk leads the homepage as a wide card with its latest piece
// shown alongside. The other four sit below in a 2x2 grid. Currently set
// to Home & Services because that's where the only completed article lives;
// flip this single string when the editorial centre of gravity shifts.
const FEATURED_DESK: typeof DESK_ORDER[number] = 'home-and-services';

const allDesks = await getCollection('desks');
const allArticles = await getCollection('articles');

// Each desk panel shows its single most recent live piece — automatic
// freshness signal, no editorial decision to "feature" anything each time.
const desks = DESK_ORDER.map((slug) => {
  const desk = allDesks.find((d) => d.data.slug === slug);
  if (!desk) throw new Error(`Missing desk metadata for ${slug}`);
  const pieces = allArticles
    .filter((a) => a.data.desk === slug && !a.data.retracted)
    .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
    .slice(0, 1);
  return { desk: desk.data, pieces };
});

const featuredDesk = desks.find((d) => d.desk.slug === FEATURED_DESK);
const otherDesks = desks.filter((d) => d.desk.slug !== FEATURED_DESK);

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const description =
  'The Ledger is a place where decisions get explained honestly — the trade-offs, limits, hidden costs, and real-world consequences most rankings and quick answers skip.';

// WebSite is the publication-level entity. SearchAction deliberately omitted
// until on-site search exists (Pagefind planned at ~60 articles); declaring
// it now would point Google at search infrastructure that does not yet exist.
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('#website', Astro.site).href,
  name: 'The Ledger',
  url: new URL('/', Astro.site).href,
  description: 'A decision-quality publication.',
  inLanguage: 'en',
  publisher: { '@id': new URL('#organization', Astro.site).href },
};
---
<BaseLayout
  title="The Ledger — A decision-quality publication"
  description={description}
  jsonLd={websiteJsonLd}
>

  <section class="hero">
    <div class="container">
      <h1 class="hero__line">
        The Ledger helps people see what a choice <em>really</em> costs after the easy answer stops working.
      </h1>
    </div>
  </section>

  <section class="method" aria-label="The method">
    <div class="container">
      <div class="method__inner">
        <p class="method__body">
          Every conclusion published here shows its working — the assumptions made, the evidence considered, the limits that apply, and the point at which it stops being true. We call this <em>Paper Trail</em>. It is how The Ledger keeps itself honest.
        </p>
        <a href="/how-the-ledger-works/" class="method__link">Read the method</a>
      </div>
    </div>
  </section>

  <section class="desks" aria-label="Sections">
    <div class="container">
      <div class="desks__header">
        <p class="desks__intro">
          Five areas The Ledger writes about — organised by the kind of decision, not the kind of reader.
        </p>
      </div>

      {featuredDesk && (
        <article class="featured">
          <div class="featured__intro">
            <p class="featured__eyebrow">Featured · <span>{featuredDesk.desk.numeral}</span></p>
            <h2 class="featured__name">
              <a href={`/${featuredDesk.desk.slug}/`}>{featuredDesk.desk.name}</a>
            </h2>
            <p class="featured__about">{featuredDesk.desk.about}</p>
          </div>
          <div class="featured__divider" aria-hidden="true"></div>
          <div class="featured__piece-wrap">
            {featuredDesk.pieces.length === 0 ? (
              <p class="featured__empty">First piece coming soon.</p>
            ) : (
              featuredDesk.pieces.map((piece) => (
                <a href={`/${piece.data.desk}/${piece.data.slug}/`} class="featured__piece">
                  <p class="featured__piece-label">Latest</p>
                  <span class="featured__piece-title">{piece.data.title}</span>
                  <time class="featured__piece-date" datetime={piece.data.publishDate.toISOString()}>
                    {dateFmt.format(piece.data.publishDate)}
                  </time>
                </a>
              ))
            )}
          </div>
        </article>
      )}

      <div class="desks__grid">
        {otherDesks.map(({ desk, pieces }) => (
          <article class="desk">
            <p class="desk__numeral">{desk.numeral}</p>
            <h2 class="desk__name">
              <a href={`/${desk.slug}/`}>{desk.name}</a>
            </h2>
            <p class="desk__about">{desk.about}</p>
            <div class="desk__pieces">
              {pieces.length === 0 ? (
                <p class="desk__empty">First piece coming soon.</p>
              ) : (
                pieces.map((piece) => (
                  <a href={`/${piece.data.desk}/${piece.data.slug}/`} class="desk__piece">
                    <span class="desk__piece-title">{piece.data.title}</span>
                    <time class="desk__piece-date" datetime={piece.data.publishDate.toISOString()}>
                      {dateFmt.format(piece.data.publishDate)}
                    </time>
                  </a>
                ))
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="statement" aria-label="Editorial statement">
    <div class="container">
      <p>"The Ledger publishes when there is something worth saying — not because a calendar demands it."</p>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: 88px 0 104px;
    border-bottom: 1px solid var(--rule);
  }
  .hero__eyebrow { margin-bottom: 36px; }
  .hero__line {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    max-width: 980px;
    margin-bottom: 44px;
    color: var(--ink);
  }
  .hero__line em { font-style: italic; font-weight: 400; }
  .hero__support {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 700px;
  }

  .method {
    padding: 80px 0;
    border-bottom: 1px solid var(--rule);
  }
  .method__inner {
    max-width: 680px;
  }
  .method__body {
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .method__body em { font-style: italic; }
  .method__link {
    display: inline-block;
    margin-top: 22px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 3px;
    transition: color 0.15s, border-color 0.15s;
  }
  .method__link:hover { color: var(--accent); border-color: var(--accent); }

  .desks { padding: 88px 0 96px; }
  .desks__header {
    margin-bottom: 56px;
  }
  .desks__intro {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 560px;
    margin: 0;
  }

  /* Featured card. Two-column diptych on desktop: desk intro left, latest
     piece right, separated by a vertical hairline. Framed top and bottom by
     a thin rule so it reads as a distinct page-leading block, not a regular
     card scaled up. Stacks to single-column on small screens. */
  .featured {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 56px;
    align-items: start;
    padding: 48px 0 52px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 72px;
  }
  .featured__eyebrow {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-3);
    margin: 0 0 18px;
  }
  .featured__eyebrow span {
    font-family: var(--serif);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.02em;
    margin-left: 4px;
  }
  .featured__name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(36px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }
  .featured__name a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s;
  }
  .featured__name a:hover { text-decoration: underline; }
  .featured__about {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
    max-width: 460px;
  }
  .featured__divider {
    background: var(--rule);
    align-self: stretch;
  }
  .featured__piece-label {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-3);
    margin: 0 0 18px;
  }
  .featured__piece {
    display: block;
    color: var(--ink);
    text-decoration: none;
  }
  .featured__piece-title {
    display: block;
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.18;
    letter-spacing: -0.012em;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 12px;
    transition: color 0.15s, border-color 0.15s;
  }
  .featured__piece:hover .featured__piece-title {
    color: var(--accent);
    border-color: var(--accent);
  }
  .featured__piece-date {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
  }
  .featured__empty {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin: 0;
  }

  /* 2x2 grid for the other four desks. Even rows, no centring gymnastics —
     four cards in two columns always fills both rows cleanly. */
  .desks__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 72px 56px;
  }
  .desk { position: relative; }
  .desk__numeral {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--ink-3);
    margin-bottom: 14px;
    letter-spacing: 0.02em;
  }
  .desk__name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin-bottom: 14px;
  }
  .desk__name a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s;
  }
  .desk__name a:hover { text-decoration: underline; }
  .desk__about {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin-bottom: 22px;
    max-width: 420px;
  }
  /* No top border now — the previous internal divider was removed so the
     card flows: numeral → name → about → article (or empty state). */
  .desk__pieces {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .desk__empty {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  /* Article link: neutral ink colour with a permanent underline rule under
     the title (matching the publication's prose-link convention — border-
     bottom in var(--rule) grey, accent on hover). The oxblood signal is
     reserved for interaction, not the default state. Date stays its small
     grey label regardless of hover so the metadata reads consistently. */
  .desk__piece {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--ink);
    text-decoration: none;
  }
  .desk__piece-title {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.005em;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 6px;
    transition: color 0.15s, border-color 0.15s;
  }
  .desk__piece:hover .desk__piece-title {
    color: var(--accent);
    border-color: var(--accent);
  }
  .desk__piece-date {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
  }

  .statement {
    border-top: 1px solid var(--rule);
    padding: 80px 0;
    text-align: center;
  }
  .statement p {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.35;
    color: var(--ink);
    max-width: 780px;
    margin: 0 auto;
    letter-spacing: -0.005em;
  }

  /* Mid-narrow: featured stacks to single column. Vertical hairline becomes
     a horizontal one between the intro and the piece. */
  @media (max-width: 900px) {
    .hero { padding: 80px 0 72px; }
    .statement { padding: 60px 0; }
    .featured {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 0 44px;
    }
    .featured__divider {
      height: 1px;
      width: 100%;
    }
  }
  /* Mobile: 2x2 collapses to single column, dividers between cards (the
     flex gap alone reads as floating at this width). Featured already
     stacked from the 900px breakpoint above. */
  @media (max-width: 640px) {
    .desks__grid { grid-template-columns: 1fr; gap: 0; }
    .desks__grid > .desk:not(:last-child) {
      padding-bottom: 40px;
      margin-bottom: 40px;
      border-bottom: 1px solid var(--rule);
    }
    .featured { margin-bottom: 48px; }
  }
  @media (max-width: 480px) {
    .desk__name { font-size: 26px; }
    .desk__piece-title { font-size: 18px; }
    .desk__empty { font-size: 18px; }
    .featured__name { font-size: 32px; }
    .featured__piece-title { font-size: 22px; }
  }
</style>
