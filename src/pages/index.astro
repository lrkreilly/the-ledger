---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const DESK_ORDER = [
  'value-and-trade-offs',
  'home-and-services',
  'internet-claims',
  'work-and-standards',
  'education-and-learning',
] as const;

const allDesks = await getCollection('desks');
const allArticles = await getCollection('articles');

// Each desk panel shows its single most recent live piece — automatic
// freshness signal, no editorial decision to "feature" anything each time.
const desks = DESK_ORDER.map((slug) => {
  const desk = allDesks.find((d) => d.data.slug === slug);
  if (!desk) throw new Error(`Missing desk metadata for ${slug}`);
  const pieces = allArticles
    .filter((a) => a.data.desk === slug && !a.data.retracted)
    .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
    .slice(0, 1);
  return { desk: desk.data, pieces };
});

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const description =
  'The Ledger is a place where decisions get explained honestly — the trade-offs, limits, hidden costs, and real-world consequences most rankings and quick answers skip.';
---
<BaseLayout
  title="The Ledger — A decision-quality publication"
  description={description}
>

  <section class="hero">
    <div class="container">
      <h1 class="hero__line">
        The Ledger helps people see what a choice <em>really</em> costs after the easy answer stops working.
      </h1>
    </div>
  </section>

  <section class="method" aria-label="The method">
    <div class="container">
      <div class="method__inner">
        <p class="method__body">
          Every conclusion published here shows its working — the assumptions made, the evidence considered, the limits that apply, and the point at which it stops being true. We call this <em>Paper Trail</em>. It is how The Ledger keeps itself honest.
        </p>
        <a href="/how-the-ledger-works/" class="method__link">Read the method</a>
      </div>
    </div>
  </section>

  <section class="desks" aria-label="Sections">
    <div class="container">
      <div class="desks__header">
        <p class="desks__intro">
          Five areas The Ledger writes about — organised by the kind of decision, not the kind of reader.
        </p>
      </div>

      <div class="desks__grid">
        {desks.map(({ desk, pieces }) => (
          <article class="desk">
            <p class="desk__numeral">{desk.numeral}</p>
            <h2 class="desk__name">
              <a href={`/${desk.slug}/`}>{desk.name}</a>
            </h2>
            <p class="desk__about">{desk.about}</p>
            <div class="desk__pieces">
              {pieces.length === 0 ? (
                <p class="desk__empty">First piece coming soon.</p>
              ) : (
                pieces.map((piece) => (
                  <a href={`/${piece.data.desk}/${piece.data.slug}/`} class="desk__piece">
                    <span class="desk__piece-title">{piece.data.title}</span>
                    <time class="desk__piece-date" datetime={piece.data.publishDate.toISOString()}>
                      {dateFmt.format(piece.data.publishDate)}
                    </time>
                  </a>
                ))
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="statement" aria-label="Editorial statement">
    <div class="container">
      <p>"The Ledger publishes when there is something worth saying — not because a calendar demands it."</p>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: 88px 0 104px;
    border-bottom: 1px solid var(--rule);
  }
  .hero__eyebrow { margin-bottom: 36px; }
  .hero__line {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    max-width: 980px;
    margin-bottom: 44px;
    color: var(--ink);
  }
  .hero__line em { font-style: italic; font-weight: 400; }
  .hero__support {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 700px;
  }

  .method {
    padding: 80px 0;
    border-bottom: 1px solid var(--rule);
  }
  .method__inner {
    max-width: 680px;
  }
  .method__body {
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .method__body em { font-style: italic; }
  .method__link {
    display: inline-block;
    margin-top: 22px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 3px;
    transition: color 0.15s, border-color 0.15s;
  }
  .method__link:hover { color: var(--accent); border-color: var(--accent); }

  .desks { padding: 88px 0 96px; }
  .desks__header {
    margin-bottom: 56px;
  }
  .desks__intro {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 560px;
    margin: 0;
  }
  /* 3+2 grid for five desks. Bottom row left-aligns (grid default) so the
     empty slot reads as intentional structure, not a centred 5-card row. */
  .desks__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 72px 56px;
  }
  .desk { position: relative; }
  .desk__numeral {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--ink-3);
    margin-bottom: 14px;
    letter-spacing: 0.02em;
  }
  .desk__name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin-bottom: 14px;
  }
  .desk__name a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s;
  }
  .desk__name a:hover { text-decoration: underline; }
  .desk__about {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin-bottom: 22px;
    max-width: 420px;
  }
  /* No top border now — the previous internal divider was removed so the
     card flows: numeral → name → about → article (or empty state). */
  .desk__pieces {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .desk__empty {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  .desk__piece {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s;
  }
  .desk__piece:hover { text-decoration: underline; }
  .desk__piece-title {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.005em;
  }
  .desk__piece-date {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-3);
  }

  .statement {
    border-top: 1px solid var(--rule);
    padding: 80px 0;
    text-align: center;
  }
  .statement p {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.35;
    color: var(--ink);
    max-width: 780px;
    margin: 0 auto;
    letter-spacing: -0.005em;
  }

  /* Tablet: 2 columns. Bottom row will have one card with an empty slot to
     its right, same intentional-structure read as the 3+2 desktop layout. */
  @media (max-width: 1024px) {
    .desks__grid { grid-template-columns: repeat(2, 1fr); gap: 56px 48px; }
  }
  @media (max-width: 900px) {
    .hero { padding: 80px 0 72px; }
    .statement { padding: 60px 0; }
  }
  /* Mobile: single column. Add thin dividers between stacked cards — at this
     viewport, grid spacing alone reads as floating; the rule gives the stack
     visible structure. Not applied on tablet/desktop where grid gaps work. */
  @media (max-width: 640px) {
    .desks__grid { grid-template-columns: 1fr; gap: 0; }
    .desks__grid > .desk:not(:last-child) {
      padding-bottom: 40px;
      margin-bottom: 40px;
      border-bottom: 1px solid var(--rule);
    }
  }
  @media (max-width: 480px) {
    .desk__name { font-size: 26px; }
    .desk__piece-title { font-size: 18px; }
    .desk__empty { font-size: 18px; }
  }
</style>
