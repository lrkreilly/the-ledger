---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DeskHeader from '../../components/DeskHeader.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const desks = await getCollection('desks');
  return desks.map((desk) => ({
    params: { desk: desk.data.slug },
    props: { desk: desk.data },
  }));
}

const { desk } = Astro.props;
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((a) => a.data.desk === desk.slug && !a.data.retracted)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const siteHref = new URL('/', Astro.site).href;
const deskUrl = new URL(`/${desk.slug}/`, Astro.site).href;

// CollectionPage for the desk. mainEntity (ItemList of articles) is only
// emitted when articles exist — for empty desks (e.g. education-and-learning
// at launch), omitting it reads cleaner than declaring an empty
// `itemListElement: []`. The ItemList appears automatically when the first
// article ships.
const collectionPageJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: desk.name,
  description: desk.about,
  url: deskUrl,
  inLanguage: 'en',
  isPartOf: { '@id': new URL('#website', Astro.site).href },
  publisher: { '@id': new URL('#organization', Astro.site).href },
};

if (articles.length > 0) {
  collectionPageJsonLd.mainEntity = {
    '@type': 'ItemList',
    itemListElement: articles.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(`/${a.data.desk}/${a.data.slug}/`, Astro.site).href,
    })),
  };
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteHref },
    { '@type': 'ListItem', position: 2, name: desk.name, item: deskUrl },
  ],
};
---
<BaseLayout
  title={`${desk.name} — The Ledger`}
  description={desk.about}
  trimLeft={desk.name}
  trimRight={desk.lens}
  jsonLd={[collectionPageJsonLd, breadcrumbJsonLd]}
>
  <DeskHeader
    numeral={desk.numeral}
    name={desk.name}
    lens={desk.lens}
    dominantQuestion={desk.dominantQuestion}
    about={desk.about}
  />

  <section class="desk-list">
    <div class="container">
      {articles.length === 0 ? (
        <p class="desk-list__empty">The first piece for this desk is being prepared.</p>
      ) : (
        articles.map((a) => (
          <ArticleCard
            href={`/${a.data.desk}/${a.data.slug}/`}
            title={a.data.title}
            summary={a.data.summary}
            publishDate={a.data.publishDate}
          />
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .desk-list { padding: 56px 0 96px; }
  .desk-list__empty {
    font-family: var(--serif);
    font-style: italic;
    font-size: 20px;
    color: var(--ink-3);
    padding: 40px 0;
  }
</style>
