---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const desks = await getCollection('desks');
  return articles.map((article) => {
    const desk = desks.find((d) => d.data.slug === article.data.desk);
    if (!desk) throw new Error(`Article ${article.id} references unknown desk ${article.data.desk}`);
    return {
      params: { desk: article.data.desk, slug: article.data.slug },
      props: { article, desk: desk.data },
    };
  });
}

const { article, desk } = Astro.props;
const { Content } = await render(article);

// Word count derived from raw Markdown body for Article.wordCount JSON-LD.
// Strips fenced code blocks (technical, not prose), inline code, image
// syntax, and link URLs (keeping link text). Counts whitespace-separated
// tokens containing at least one word character — filters out punctuation-
// only tokens and stray Markdown markers.
function countWords(markdown: string): number {
  return markdown
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]*`/g, '')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/<[^>]+>/g, '')
    .split(/\s+/)
    .filter((t) => t.length > 0 && /\w/.test(t))
    .length;
}
const wordCount = countWords(article.body ?? '');
---
<ArticleLayout
  title={article.data.title}
  summary={article.data.summary}
  desk={article.data.desk}
  deskName={desk.name}
  deskNumeral={desk.numeral}
  slug={article.data.slug}
  author={article.data.author}
  publishDate={article.data.publishDate}
  modifiedDate={article.data.modifiedDate}
  ogImage={article.data.ogImage ?? `/og/${article.data.slug}.png`}
  wordCount={wordCount}
  paperTrail={article.data.paperTrail}
  retracted={article.data.retracted}
>
  <Content />
</ArticleLayout>
